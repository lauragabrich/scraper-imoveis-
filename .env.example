# Banco de dados - Turso (libSQL remoto)
TURSO_DATABASE_URL=libsql://seu-banco-seu-org.turso.io
TURSO_AUTH_TOKEN=seu-token-aqui

# Alternativa PostgreSQL: DATABASE_URL=postgresql://user:password@localhost:5432/imoveis_db

# Proxies (opcional - separados por vírgula)
PROXY_LIST=http://proxy1:port,http://proxy2:port

# Configurações de scraping
MAX_CONCURRENT_REQUESTS=5
REQUEST_DELAY_MIN=1.0
REQUEST_DELAY_MAX=3.0
MAX_RETRIES=3

# Diretório para cache de sitemaps
SITEMAP_CACHE_DIR=./cache/sitemaps
